<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:AvaloniaDemo.ViewModels.UserControls"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d"
			 d:DesignWidth="350" d:DesignHeight="700"
			 x:Class="AvaloniaDemo.Views.UserControls.ProfileUserControl"
			 x:DataType="vm:ProfileViewModel">

	<Design.DataContext>
		<vm:ProfileViewModel />
	</Design.DataContext>

	<ScrollViewer VerticalScrollBarVisibility="Auto"
				  HorizontalScrollBarVisibility="Disabled">
		<StackPanel Background="{DynamicResource SemiColorBg1}">

			<!-- ══ Profile Header ══ -->
			<Border Background="{DynamicResource SemiColorBg0}" Padding="16,16,16,16" Margin="0,0,0,8">
				<Grid ColumnDefinitions="Auto,*,Auto">

					<!-- 头像 -->
					<Border Grid.Column="0" Width="70" Height="70" VerticalAlignment="Top"
							CornerRadius="6" ClipToBounds="True" Margin="0,0,14,0"
							Background="#5B9BD5">
						<TextBlock Text="H"
								   FontSize="36" FontWeight="Bold" Foreground="White"
								   HorizontalAlignment="Center" VerticalAlignment="Center"/>
					</Border>

					<StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
						<TextBlock Text="{Binding Nickname}"
								   FontSize="22" FontWeight="Bold"
								   Foreground="{DynamicResource SemiColorText0}"/>
						<StackPanel Orientation="Horizontal" Spacing="4">
							<TextBlock Text="微信号：" FontSize="13"
									   Foreground="{DynamicResource SemiColorText2}"/>
							<TextBlock Text="{Binding WechatId}" FontSize="13"
									   Foreground="{DynamicResource SemiColorText2}"/>
						</StackPanel>
						<StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2,0,0">
							<Button BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1"
									Background="Transparent" CornerRadius="12"
									Padding="10,4" Command="{Binding AddStatusCommand}">
								<TextBlock Text="+ 状态" FontSize="13"
										   Foreground="{DynamicResource SemiColorText1}"/>
							</Button>
							<Button BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1"
									Background="Transparent" CornerRadius="12"
									Padding="10,4" Command="{Binding OpenFriendsCommand}">
								<StackPanel Orientation="Horizontal" Spacing="5">
									<TextBlock Text="{Binding FriendCount, StringFormat='{}{0}个朋友'}"
											   FontSize="13"
											   Foreground="{DynamicResource SemiColorText1}"/>
									<Ellipse Width="8" Height="8" Fill="#FF4444" VerticalAlignment="Center"/>
								</StackPanel>
							</Button>
						</StackPanel>
					</StackPanel>

					<!-- 二维码图标 -->
					<Button Grid.Column="2" Background="Transparent" VerticalAlignment="Center"
							Command="{Binding OpenQrCodeCommand}"
							Padding="0"
							HorizontalContentAlignment="Stretch"
							VerticalContentAlignment="Stretch"
							Width="40" Height="40">
						<Viewbox Stretch="Uniform">
							<Canvas Width="24" Height="24">
								<Path Data="M3 11H5V13H3ZM5 7H7V9H5ZM3 3V9H9V3ZM7 7H5V5H7ZM3 15H5V17H3ZM5 19H7V21H5ZM3 21V15H9V21ZM7 19H5V17H7ZM15 7H17V9H15ZM13 5V11H19V5ZM17 9H15V7H17ZM13 13H15V15H13ZM15 15H17V17H15ZM13 17H15V19H13ZM17 13H19V15H17ZM15 19H17V21H15ZM17 17H19V19H17ZM19 13H21V15H19ZM19 19H21V21H19ZM21 13V19H15V21H21V19H23V13ZM13 21H11V13H13Z"
									  Fill="{DynamicResource SemiColorText2}"/>
							</Canvas>
						</Viewbox>
					</Button>
				</Grid>
			</Border>

			<!-- ══ 服务 ══ -->
			<Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8">
				<Button Background="Transparent" HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Stretch" Height="52" Padding="0"
						Command="{Binding OpenServiceCommand}">
					<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
						<Viewbox Grid.Column="0" Width="24" Height="24"
								 HorizontalAlignment="Center" VerticalAlignment="Center">
							<Canvas Width="24" Height="24">
								<Path Data="M20 4H4C2.89 4 2.01 4.89 2.01 6L2 18C2 19.11 2.89 20 4 20H20C21.11 20 22 19.11 22 18V6C22 4.89 21.11 4 20 4ZM20 18H4V12H20V18ZM20 8H4V6H20V8Z"
									  Fill="#07C160"/>
							</Canvas>
						</Viewbox>
						<TextBlock Grid.Column="1" Text="服务" FontSize="16"
								   Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
						<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
							<Canvas Width="24" Height="24">
								<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
									  Fill="{DynamicResource SemiColorText2}"/>
							</Canvas>
						</Viewbox>
					</Grid>
				</Button>
			</Border>

			<!-- ══ 收藏 / 朋友圈 / 视频号 / 订单 / 表情 ══ -->
			<Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8">
				<StackPanel>

					<!-- 收藏 -->
					<Button Background="Transparent" HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch" Height="52" Padding="0"
							Command="{Binding OpenFavoritesCommand}">
						<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
							<Viewbox Grid.Column="0" Width="24" Height="24"
									 HorizontalAlignment="Center" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M17 3H7C5.9 3 5 3.9 5 5V21L12 18L19 21V5C19 3.9 18.1 3 17 3Z"
										  Fill="#FA8C16"/>
								</Canvas>
							</Viewbox>
							<TextBlock Grid.Column="1" Text="收藏" FontSize="16"
									   Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
							<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Grid>
					</Button>
					<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

					<!-- 朋友圈 -->
					<Button Background="Transparent" HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch" Height="52" Padding="0"
							Command="{Binding OpenMomentsCommand}">
						<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
							<Canvas Grid.Column="0" Width="28" Height="28"
									HorizontalAlignment="Center" VerticalAlignment="Center">
								<Ellipse Canvas.Left="0"  Canvas.Top="0"  Width="12" Height="12" Fill="#E74C3C"/>
								<Ellipse Canvas.Left="16" Canvas.Top="0"  Width="12" Height="12" Fill="#2ECC71"/>
								<Ellipse Canvas.Left="0"  Canvas.Top="16" Width="12" Height="12" Fill="#3498DB"/>
								<Ellipse Canvas.Left="16" Canvas.Top="16" Width="12" Height="12" Fill="#F1C40F"/>
							</Canvas>
							<TextBlock Grid.Column="1" Text="朋友圈" FontSize="16"
									   Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
							<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Grid>
					</Button>
					<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

					<!-- 视频号和公众号 -->
					<Button Background="Transparent" HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch" Height="52" Padding="0"
							Command="{Binding OpenChannelsCommand}">
						<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
							<Viewbox Grid.Column="0" Width="24" Height="24"
									 HorizontalAlignment="Center" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M17 10.5V7C17 6.45 16.55 6 16 6H4C3.45 6 3 6.45 3 7V17C3 17.55 3.45 18 4 18H16C16.55 18 17 17.55 17 17V13.5L21 17.5V6.5L17 10.5Z"
										  Fill="#FF8C00"/>
								</Canvas>
							</Viewbox>
							<TextBlock Grid.Column="1" Text="视频号和公众号" FontSize="16"
									   Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
							<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Grid>
					</Button>
					<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

					<!-- 订单与卡包 -->
					<Button Background="Transparent" HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch" Height="52" Padding="0"
							Command="{Binding OpenOrdersCommand}">
						<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
							<Viewbox Grid.Column="0" Width="24" Height="24"
									 HorizontalAlignment="Center" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M19 6H17.82C17.4 4.84 16.3 4 15 4H9C7.7 4 6.6 4.84 6.18 6H5C3.9 6 3 6.9 3 8V20C3 21.1 3.9 22 5 22H19C20.1 22 21 21.1 21 20V8C21 6.9 20.1 6 19 6ZM9 6H15V8H9V6ZM19 20H5V8H19V20Z"
										  Fill="#E74C3C"/>
								</Canvas>
							</Viewbox>
							<TextBlock Grid.Column="1" Text="订单与卡包" FontSize="16"
									   Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
							<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Grid>
					</Button>
					<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

					<!-- 表情 -->
					<Button Background="Transparent" HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch" Height="52" Padding="0"
							Command="{Binding OpenEmojiCommand}">
						<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
							<Viewbox Grid.Column="0" Width="24" Height="24"
									 HorizontalAlignment="Center" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M11.99 2C6.47 2 2 6.48 2 12C2 17.52 6.47 22 11.99 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 11.99 2ZM12 20C7.58 20 4 16.42 4 12C4 7.58 7.58 4 12 4C16.42 4 20 7.58 20 12C20 16.42 16.42 20 12 20ZM15.5 11C16.33 11 17 10.33 17 9.5C17 8.67 16.33 8 15.5 8C14.67 8 14 8.67 14 9.5C14 10.33 14.67 11 15.5 11ZM8.5 11C9.33 11 10 10.33 10 9.5C10 8.67 9.33 8 8.5 8C7.67 8 7 8.67 7 9.5C7 10.33 7.67 11 8.5 11ZM12 17.5C14.33 17.5 16.31 16.04 17.11 14H6.89C7.69 16.04 9.67 17.5 12 17.5Z"
										  Fill="#F1C40F"/>
								</Canvas>
							</Viewbox>
							<TextBlock Grid.Column="1" Text="表情" FontSize="16"
									   Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
							<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Grid>
					</Button>
				</StackPanel>
			</Border>

			<!-- ══ 设置 ══ -->
			<Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8">
				<Button Background="Transparent" HorizontalAlignment="Stretch"
						HorizontalContentAlignment="Stretch" Height="52" Padding="0"
						Command="{Binding OpenSettingsCommand}">
					<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
						<Viewbox Grid.Column="0" Width="24" Height="24"
								 HorizontalAlignment="Center" VerticalAlignment="Center">
							<Canvas Width="24" Height="24">
								<Path Data="M19.14 12.94C19.18 12.64 19.2 12.33 19.2 12C19.2 11.68 19.18 11.36 19.13 11.06L21.16 9.48C21.34 9.34 21.39 9.07 21.28 8.87L19.36 5.55C19.24 5.33 18.99 5.26 18.77 5.33L16.38 6.29C15.88 5.91 15.35 5.59 14.76 5.35L14.4 2.81C14.36 2.57 14.16 2.4 13.92 2.4H10.08C9.84 2.4 9.65 2.57 9.61 2.81L9.25 5.35C8.66 5.59 8.12 5.92 7.63 6.29L5.24 5.33C5.02 5.25 4.77 5.33 4.65 5.55L2.74 8.87C2.62 9.08 2.66 9.34 2.86 9.48L4.89 11.06C4.84 11.36 4.8 11.69 4.8 12C4.8 12.31 4.82 12.64 4.87 12.94L2.84 14.52C2.66 14.66 2.61 14.93 2.72 15.13L4.64 18.45C4.76 18.67 5.01 18.74 5.23 18.67L7.62 17.71C8.12 18.09 8.65 18.41 9.24 18.65L9.6 21.19C9.65 21.43 9.84 21.6 10.08 21.6H13.92C14.16 21.6 14.36 21.43 14.39 21.19L14.75 18.65C15.34 18.41 15.88 18.07 16.37 17.71L18.76 18.67C18.98 18.75 19.23 18.67 19.35 18.45L21.27 15.13C21.39 14.91 21.34 14.66 21.15 14.52L19.14 12.94ZM12 15.6C10.02 15.6 8.4 13.98 8.4 12C8.4 10.02 10.02 8.4 12 8.4C13.98 8.4 15.6 10.02 15.6 12C15.6 13.98 13.98 15.6 12 15.6Z"
									  Fill="#8E8E93"/>
							</Canvas>
						</Viewbox>
						<TextBlock Grid.Column="1" Text="设置" FontSize="16"
								   Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
						<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
							<Canvas Width="24" Height="24">
								<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
									  Fill="{DynamicResource SemiColorText2}"/>
							</Canvas>
						</Viewbox>
					</Grid>
				</Button>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>