<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaDemo.ViewModels.Windows"
             xmlns:pageVm="using:AvaloniaDemo.ViewModels.UserControls"
             xmlns:views="using:AvaloniaDemo.Views.UserControls"
             xmlns:conv="using:AvaloniaDemo.Tools.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="350" d:DesignHeight="700"
             x:CompileBindings="True"
             x:DataType="vm:MainWindowViewModel"
             x:Class="AvaloniaDemo.Views.UserControls.MainView">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <UserControl.DataTemplates>
        <DataTemplate DataType="{x:Type pageVm:ChatViewModel}">
            <views:ChatUserControl />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pageVm:ContactsViewModel}">
            <views:ContactsUserControl />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pageVm:DiscoverViewModel}">
            <views:DiscoverUserControl />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pageVm:ProfileViewModel}">
            <views:ProfileUserControl />
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Background="#F0F0F0">

        <!-- ══ Row 0: 状态栏安全区（避开摄像头/刘海，高度 44） ══ -->
        <Border Grid.Row="0" Height="44" Background="White" />

        <!-- ══ Row 1: 标题栏（仅非"我"页显示） ══ -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,0.8"
                Padding="16,8"
                IsVisible="{Binding ShowTitleBar}">
            <Grid ColumnDefinitions="44,*,44">
                <Panel Grid.Column="0" />
                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentPageTitle}"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="#1A1A1A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                <Panel Grid.Column="2" />
            </Grid>
        </Border>

        <!-- ══ Row 2: 页面内容区 ══ -->
        <ContentControl Grid.Row="2"
                        Content="{Binding CurrentPage}"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />

        <!-- ══ Row 3: 底部 TabBar ══ -->
        <Border Grid.Row="3"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0.8,0,0"
                Padding="0,6,0,0">
            <Grid ColumnDefinitions="*,*,*,*">

                <!-- 微信 Tab -->
                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding SwitchToChatCommand}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <!-- 聊天气泡图标（纯 Path，无字体依赖） -->
                                <Path Data="M20 2H4C2.9 2 2 2.9 2 4V22L6 18H20C21.1 18 22 17.1 22 16V4C22 2.9 21.1 2 20 2ZM20 16H5.17L4 17.17V4H20V16Z"
                                      Fill="{Binding IsChatActive, Converter={StaticResource BoolToTabColorConverter}}"/>
                                <Path Data="M7 9H17V11H7ZM7 12H14V14H7Z"
                                      Fill="{Binding IsChatActive, Converter={StaticResource BoolToTabColorConverter}}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="微信"
                                   FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding IsChatActive, Converter={StaticResource BoolToTabColorConverter}}" />
                    </StackPanel>
                </Button>

                <!-- 通讯录 Tab -->
                <Button Grid.Column="1"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding SwitchToContactsCommand}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <!-- 联系人图标 -->
                                <Path Data="M16 11C17.66 11 18.99 9.66 18.99 8S17.66 5 16 5C14.34 5 13 6.34 13 8S14.34 11 16 11ZM8 11C9.66 11 10.99 9.66 10.99 8S9.66 5 8 5C6.34 5 5 6.34 5 8S6.34 11 8 11ZM8 13C5.67 13 1 14.17 1 16.5V19H15V16.5C15 14.17 10.33 13 8 13ZM16 13C15.71 13 15.38 13.02 15.03 13.05C16.19 13.89 17 15.02 17 16.5V19H23V16.5C23 14.17 18.33 13 16 13Z"
                                      Fill="{Binding IsContactsActive, Converter={StaticResource BoolToTabColorConverter}}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="通讯录"
                                   FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding IsContactsActive, Converter={StaticResource BoolToTabColorConverter}}" />
                    </StackPanel>
                </Button>

                <!-- 发现 Tab（带红点） -->
                <Button Grid.Column="2"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding SwitchToDiscoverCommand}">
                    <Panel>
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <!-- 指南针/发现图标 -->
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 20C7.59 20 4 16.41 4 12C4 7.59 7.59 4 12 4C16.41 4 20 7.59 20 12C20 16.41 16.41 20 12 20Z"
                                          Fill="{Binding IsDiscoverActive, Converter={StaticResource BoolToTabColorConverter}}"/>
                                    <Path Data="M6.5 17.5L9.5 9.5L17.5 6.5L14.5 14.5L6.5 17.5Z"
                                          Fill="{Binding IsDiscoverActive, Converter={StaticResource BoolToTabColorConverter}}"/>
                                    <Path Data="M12 10.5C11.17 10.5 10.5 11.17 10.5 12C10.5 12.83 11.17 13.5 12 13.5C12.83 13.5 13.5 12.83 13.5 12C13.5 11.17 12.83 10.5 12 10.5Z"
                                          Fill="White"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="发现"
                                       FontSize="16" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Foreground="{Binding IsDiscoverActive, Converter={StaticResource BoolToTabColorConverter}}" />
                        </StackPanel>
                        <!-- 红点提示 -->
                        <Ellipse Width="8" Height="8" Fill="#FF4444"
                                 HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,0,8,0" />
                    </Panel>
                </Button>

                <!-- 我 Tab -->
                <Button Grid.Column="3"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding SwitchToProfileCommand}">
                    <StackPanel HorizontalAlignment="Center" Spacing="3">
                        <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <!-- 单人图标 -->
                                <Path Data="M12 12C14.21 12 16 10.21 16 8C16 5.79 14.21 4 12 4C9.79 4 8 5.79 8 8C8 10.21 9.79 12 12 12ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z"
                                      Fill="{Binding IsProfileActive, Converter={StaticResource BoolToTabColorConverter}}"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="我"
                                    FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="{Binding IsProfileActive, Converter={StaticResource BoolToTabColorConverter}}" />
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

        <!-- ══ Row 4: Home Indicator 安全区（底部导航条区域） ══ -->
        <Border Grid.Row="4" Height="10" Background="White" />
    </Grid>
</UserControl>
