<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:AvaloniaDemo.ViewModels.UserControls"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 mc:Ignorable="d"
			 d:DesignWidth="350" d:DesignHeight="700"
			 x:Class="AvaloniaDemo.Views.UserControls.ContactsUserControl"
			 x:DataType="vm:ContactsViewModel">

	<Design.DataContext>
		<vm:ContactItemViewModel />
	</Design.DataContext>

	<ScrollViewer VerticalScrollBarVisibility="Auto">
		<StackPanel Background="{DynamicResource SemiColorBg1}">

			<!-- ══ 快捷功能入口 ══ -->
			<Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8">
				<StackPanel>

					<!-- 新的朋友 -->
					<Button Background="Transparent" HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch" Height="52" Padding="0"
							Command="{Binding NewFriendRequestCommand}">
						<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
							<Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
									Background="#07C160" HorizontalAlignment="Center" VerticalAlignment="Center">
								<Viewbox Width="20" Height="20">
									<Canvas Width="24" Height="24">
										<Path Data="M15 12C17.21 12 19 10.21 19 8C19 5.79 17.21 4 15 4C12.79 4 11 5.79 11 8C11 10.21 12.79 12 15 12ZM6 10V7H4V10H1V12H4V15H6V12H9V10H6ZM15 14C12.33 14 7 15.34 7 18V20H23V18C23 15.34 17.67 14 15 14Z"
											  Fill="White"/>
									</Canvas>
								</Viewbox>
							</Border>
							<TextBlock Grid.Column="1" Text="新的朋友"
									   FontSize="16"
									   Foreground="{DynamicResource SemiColorText0}"
									   VerticalAlignment="Center"/>
							<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Grid>
					</Button>
					<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

					<!-- 群聊 -->
					<Button Background="Transparent" HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch" Height="52" Padding="0"
							Command="{Binding OpenGroupChatCommand}">
						<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
							<Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
									Background="#3498DB" HorizontalAlignment="Center" VerticalAlignment="Center">
								<Viewbox Width="20" Height="20">
									<Canvas Width="24" Height="24">
										<Path Data="M16 11C17.66 11 18.99 9.66 18.99 8S17.66 5 16 5C14.34 5 13 6.34 13 8S14.34 11 16 11ZM8 11C9.66 11 10.99 9.66 10.99 8S9.66 5 8 5C6.34 5 5 6.34 5 8S6.34 11 8 11ZM8 13C5.67 13 1 14.17 1 16.5V19H15V16.5C15 14.17 10.33 13 8 13ZM16 13C15.71 13 15.38 13.02 15.03 13.05C16.19 13.89 17 15.02 17 16.5V19H23V16.5C23 14.17 18.33 13 16 13Z"
											  Fill="White"/>
									</Canvas>
								</Viewbox>
							</Border>
							<TextBlock Grid.Column="1" Text="群聊"
									   FontSize="16"
									   Foreground="{DynamicResource SemiColorText0}"
									   VerticalAlignment="Center"/>
							<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Grid>
					</Button>
					<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

					<!-- 标签 -->
					<Button Background="Transparent" HorizontalAlignment="Stretch"
							HorizontalContentAlignment="Stretch" Height="52" Padding="0"
							Command="{Binding OpenTagListCommand}">
						<Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
							<Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
									Background="#F39C12" HorizontalAlignment="Center" VerticalAlignment="Center">
								<Viewbox Width="20" Height="20">
									<Canvas Width="24" Height="24">
										<Path Data="M17.63 5.84C17.27 5.33 16.67 5 16 5L5 5.01C3.9 5.01 3 5.9 3 7V17C3 18.1 3.9 18.99 5 18.99L16 19C16.67 19 17.27 18.67 17.63 18.16L22 12L17.63 5.84Z"
											  Fill="White"/>
									</Canvas>
								</Viewbox>
							</Border>
							<TextBlock Grid.Column="1" Text="标签"
									   FontSize="16"
									   Foreground="{DynamicResource SemiColorText0}"
									   VerticalAlignment="Center"/>
							<Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
								<Canvas Width="24" Height="24">
									<Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Grid>
					</Button>

				</StackPanel>
			</Border>

			<!-- ══ 联系人列表 ══ -->
			<Border Background="{DynamicResource SemiColorBg0}">
				<ItemsControl ItemsSource="{Binding Contacts}">
					<ItemsControl.ItemTemplate>
						<DataTemplate x:DataType="vm:ContactItemViewModel">
							<StackPanel>
								<Button Background="Transparent" HorizontalAlignment="Stretch"
										HorizontalContentAlignment="Stretch" Height="60" Padding="0"
										Command="{Binding $parent[ItemsControl].((vm:ContactsViewModel)DataContext).OpenContactCommand}"
										CommandParameter="{Binding}">
									<Grid ColumnDefinitions="56,*" Margin="0,0,16,0">

										<Panel Grid.Column="0"
											   Width="40" Height="40"
											   HorizontalAlignment="Center" VerticalAlignment="Center">

											<Border Width="40" Height="40" CornerRadius="8" Background="#5B9BD5"/>

											<Canvas Width="24" Height="24"
													HorizontalAlignment="Center" VerticalAlignment="Center">
												<Ellipse Canvas.Left="7" Canvas.Top="2"
														 Width="10" Height="10" Fill="White"/>
												<Rectangle Canvas.Left="4" Canvas.Top="14"
														   Width="16" Height="8"
														   RadiusX="4" RadiusY="4"
														   Fill="White"/>
											</Canvas>
										</Panel>

										<TextBlock Grid.Column="1" Text="{Binding Name}"
												   FontSize="16"
												   Foreground="{DynamicResource SemiColorText0}"
												   VerticalAlignment="Center"/>
									</Grid>
								</Button>
								<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>
							</StackPanel>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>
			</Border>

		</StackPanel>
	</ScrollViewer>
</UserControl>