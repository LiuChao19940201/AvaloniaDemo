<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AvaloniaDemo.ViewModels.UserControls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:discover="using:AvaloniaDemo.Views.UserControls.Discover"
             xmlns:discoverVm="using:AvaloniaDemo.ViewModels.UserControls.Discover"
             xmlns:profileVm="using:AvaloniaDemo.ViewModels.UserControls.Profile"
             mc:Ignorable="d"
             d:DesignWidth="350" d:DesignHeight="700"
             x:Class="AvaloniaDemo.Views.UserControls.Discover.DiscoverUserControl"
             x:DataType="discoverVm:DiscoverViewModel">

      <Design.DataContext>
        <discoverVm:DiscoverViewModel />
    </Design.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Background="{DynamicResource SemiColorBg1}">

            <!-- ══ Group 1: 朋友圈 ══ -->
            <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                    BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                <Button Background="Transparent"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Height="56" Padding="0"
                        Command="{Binding OpenMomentsCommand}">
                    <Grid ColumnDefinitions="56,*,Auto,Auto" Margin="0,0,16,0">
                        <Viewbox Grid.Column="0" Width="24" Height="24"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="M22 16V4C22 2.9 21.1 2 20 2H8C6.9 2 6 2.9 6 4V16C6 17.1 6.9 18 8 18H20C21.1 18 22 17.1 22 16ZM11 12L13.03 14.71L16 11L20 16H8L11 12ZM2 6V20C2 21.1 2.9 22 4 22H18V20H4V6H2Z"
                                      Fill="#2D8CF0"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Grid.Column="1" Text="朋友圈"
                                   FontSize="16"
                                   Foreground="{DynamicResource SemiColorText0}"
                                   VerticalAlignment="Center"/>
                        <Panel Grid.Column="2" Margin="0,0,8,0">
                            <Border Width="40" Height="40" CornerRadius="4" ClipToBounds="True"
                                    Background="#C8D8E8" VerticalAlignment="Center">
                                <Canvas Width="40" Height="40">
                                    <Rectangle Canvas.Left="0" Canvas.Top="20" Width="40" Height="20" Fill="#7CB9A8"/>
                                    <Ellipse Canvas.Left="8" Canvas.Top="6" Width="14" Height="14" Fill="#F6C244"/>
                                    <Path Data="M0,28 L10,18 L18,24 L26,14 L40,28 Z" Fill="#5FA08A"/>
                                </Canvas>
                            </Border>
                            <Ellipse Width="10" Height="10" Fill="#FF4444"
                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                     Margin="0,0,-2,-2"/>
                        </Panel>
                        <Viewbox Grid.Column="3" Width="16" Height="16" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                      Fill="{DynamicResource SemiColorText2}"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Button>
            </Border>

            <!-- ══ Group 2: 视频号 / 直播 ══ -->
            <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                    BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                <StackPanel>
                    <Button Background="Transparent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                            Command="{Binding OpenChannelsCommand}">
                        <Grid ColumnDefinitions="56,*,Auto,Auto" Margin="0,0,16,0">
                            <Viewbox Grid.Column="0" Width="24" Height="24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M17 10.5V7C17 6.45 16.55 6 16 6H4C3.45 6 3 6.45 3 7V17C3 17.55 3.45 18 4 18H16C16.55 18 17 17.55 17 17V13.5L21 17.5V6.5L17 10.5Z"
                                          Fill="#FF8C00"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="视频号"
                                       FontSize="16"
                                       Foreground="{DynamicResource SemiColorText0}"
                                       VerticalAlignment="Center"/>
                            <Panel Grid.Column="2" Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock Text="宝妈喂娃突然晕倒 撞醒后第一反应看哭无数人"
                                           FontSize="11"
                                           Foreground="{DynamicResource SemiColorText2}"
                                           MaxWidth="160" TextWrapping="Wrap" MaxLines="2"/>
                                <Ellipse Width="8" Height="8" Fill="#FF4444"
                                         HorizontalAlignment="Right" VerticalAlignment="Top"/>
                            </Panel>
                            <Viewbox Grid.Column="3" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                          Fill="{DynamicResource SemiColorText2}"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                    <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>
                    <Button Background="Transparent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                            Command="{Binding OpenLiveCommand}">
                        <Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
                            <Viewbox Grid.Column="0" Width="24" Height="24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM10 16.5V7.5L16 12L10 16.5Z"
                                          Fill="#E74C3C"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="直播"
                                       FontSize="16"
                                       Foreground="{DynamicResource SemiColorText0}"
                                       VerticalAlignment="Center"/>
                            <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                          Fill="{DynamicResource SemiColorText2}"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ══ Group 3: 扫一扫 / 听一听 ══ -->
            <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                    BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                <StackPanel>
                    <Button Background="Transparent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                            Command="{Binding OpenScanCommand}">
                        <Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
                            <Viewbox Grid.Column="0" Width="24" Height="24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M3 5V9H5V5H9V3H5C3.9 3 3 3.9 3 5ZM5 15H3V19C3 20.1 3.9 21 5 21H9V19H5V15ZM19 19H15V21H19C20.1 21 21 20.1 21 19V15H19V19ZM19 3H15V5H19V9H21V5C21 3.9 20.1 3 19 3ZM3 11H21V13H3V11Z"
                                          Fill="#3B8BDB"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="扫一扫"
                                       FontSize="16"
                                       Foreground="{DynamicResource SemiColorText0}"
                                       VerticalAlignment="Center"/>
                            <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                          Fill="{DynamicResource SemiColorText2}"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                    <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>
                    <Button Background="Transparent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                            Command="{Binding OpenListenCommand}">
                        <Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
                            <Viewbox Grid.Column="0" Width="24" Height="24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 3C7.03 3 3 7.03 3 12V18C3 19.66 4.34 21 6 21H9V13H5V12C5 8.13 8.13 5 12 5C15.87 5 19 8.13 19 12V13H15V21H18C19.66 21 21 19.66 21 18V12C21 7.03 16.97 3 12 3Z"
                                          Fill="#E74C3C"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="听一听"
                                       FontSize="16"
                                       Foreground="{DynamicResource SemiColorText0}"
                                       VerticalAlignment="Center"/>
                            <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                          Fill="{DynamicResource SemiColorText2}"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ══ Group 4: 看一看 / 搜一搜 ══ -->
            <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                    BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                <StackPanel>
                    <Button Background="Transparent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                            Command="{Binding OpenReadCommand}">
                        <Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
                            <Viewbox Grid.Column="0" Width="24" Height="24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12 4.5C7 4.5 2.73 7.61 1 12C2.73 16.39 7 19.5 12 19.5C17 19.5 21.27 16.39 23 12C21.27 7.61 17 4.5 12 4.5ZM12 17C9.24 17 7 14.76 7 12C7 9.24 9.24 7 12 7C14.76 7 17 9.24 17 12C17 14.76 14.76 17 12 17ZM12 9C10.34 9 9 10.34 9 12C9 13.66 10.34 15 12 15C13.66 15 15 13.66 15 12C15 10.34 13.66 9 12 9Z"
                                          Fill="#F1C40F"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="看一看"
                                       FontSize="16"
                                       Foreground="{DynamicResource SemiColorText0}"
                                       VerticalAlignment="Center"/>
                            <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                          Fill="{DynamicResource SemiColorText2}"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                    <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>
                    <Button Background="Transparent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                            Command="{Binding OpenSearchCommand}">
                        <Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
                            <Viewbox Grid.Column="0" Width="24" Height="24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M15.5 14H14.71L14.43 13.73C15.41 12.59 16 11.11 16 9.5C16 5.91 13.09 3 9.5 3C5.91 3 3 5.91 3 9.5C3 13.09 5.91 16 9.5 16C11.11 16 12.59 15.41 13.73 14.43L14 14.71V15.5L19 20.49L20.49 19L15.5 14ZM9.5 14C7.01 14 5 11.99 5 9.5C5 7.01 7.01 5 9.5 5C11.99 5 14 7.01 14 9.5C14 11.99 11.99 14 9.5 14Z"
                                          Fill="#E74C3C"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="搜一搜"
                                       FontSize="16"
                                       Foreground="{DynamicResource SemiColorText0}"
                                       VerticalAlignment="Center"/>
                            <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                          Fill="{DynamicResource SemiColorText2}"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ══ Group 5: 附近的人 ══ -->
            <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                    BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                <Button Background="Transparent" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                        Command="{Binding OpenNearbyCommand}">
                    <Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
                        <Viewbox Grid.Column="0" Width="24" Height="24"
                                 HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="M16 11C17.66 11 18.99 9.66 18.99 8C18.99 6.34 17.66 5 16 5C14.34 5 13 6.34 13 8C13 9.66 14.34 11 16 11ZM8 11C9.66 11 10.99 9.66 10.99 8C10.99 6.34 9.66 5 8 5C6.34 5 5 6.34 5 8C5 9.66 6.34 11 8 11ZM8 13C5.67 13 1 14.17 1 16.5V19H15V16.5C15 14.17 10.33 13 8 13ZM16 13C15.71 13 15.38 13.02 15.03 13.05C16.19 13.89 17 15.02 17 16.5V19H23V16.5C23 14.17 18.33 13 16 13Z"
                                      Fill="#3498DB"/>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Grid.Column="1" Text="附近的人"
                                   FontSize="16"
                                   Foreground="{DynamicResource SemiColorText0}"
                                   VerticalAlignment="Center"/>
                        <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                      Fill="{DynamicResource SemiColorText2}"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Button>
            </Border>

            <!-- ══ Group 6: 游戏 / 小程序 ══ -->
            <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                    BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                <StackPanel>
                    <Button Background="Transparent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                            Command="{Binding OpenGamesCommand}">
                        <Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
                            <Viewbox Grid.Column="0" Width="24" Height="24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M21 6H3C1.9 6 1 6.9 1 8V16C1 17.1 1.9 18 3 18H21C22.1 18 23 17.1 23 16V8C23 6.9 22.1 6 21 6ZM11 13H9V15H7V13H5V11H7V9H9V11H11V13ZM15.5 15C14.67 15 14 14.33 14 13.5C14 12.67 14.67 12 15.5 12C16.33 12 17 12.67 17 13.5C17 14.33 16.33 15 15.5 15ZM18.5 12C17.67 12 17 11.33 17 10.5C17 9.67 17.67 9 18.5 9C19.33 9 20 9.67 20 10.5C20 11.33 19.33 12 18.5 12Z"
                                          Fill="#2ECC71"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="游戏"
                                       FontSize="16"
                                       Foreground="{DynamicResource SemiColorText0}"
                                       VerticalAlignment="Center"/>
                            <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                          Fill="{DynamicResource SemiColorText2}"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                    <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>
                    <Button Background="Transparent" HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" Height="56" Padding="0"
                            Command="{Binding OpenMiniAppCommand}">
                        <Grid ColumnDefinitions="56,*,Auto" Margin="0,0,16,0">
                            <Viewbox Grid.Column="0" Width="24" Height="24"
                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M4 8H8V4H4V8ZM10 20H14V16H10V20ZM4 20H8V16H4V20ZM4 14H8V10H4V14ZM10 14H14V10H10V14ZM16 4V8H20V4H16ZM10 8H14V4H10V8ZM16 14H20V10H16V14ZM16 20H20V16H16V20Z"
                                          Fill="#8E44AD"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="小程序"
                                       FontSize="16"
                                       Foreground="{DynamicResource SemiColorText0}"
                                       VerticalAlignment="Center"/>
                            <Viewbox Grid.Column="2" Width="16" Height="16" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M10 6L8.59 7.41 13.17 12L8.59 16.59 10 18L16 12Z"
                                          Fill="{DynamicResource SemiColorText2}"/>
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>