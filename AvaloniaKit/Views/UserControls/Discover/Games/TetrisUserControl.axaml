<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AvaloniaKit.ViewModels.UserControls.Discover.Games"
             xmlns:converters="clr-namespace:AvaloniaKit.Converters"
             x:Class="AvaloniaKit.Views.UserControls.Discover.Games.TetrisUserControl"
             d:DesignWidth="350" d:DesignHeight="700"
             x:DataType="vm:TetrisViewModel">

    <Design.DataContext>
        <vm:TetrisViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <converters:TetrominoTypeToBrushConverter x:Key="TypeToBrush"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource SemiColorBg1}">

        <!-- ══ 导航栏 ══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SemiColorBg0}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,0,0,1"
                Padding="0,6">
            <Grid ColumnDefinitions="48,*,48,48">

                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding GoBackCommand}"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        IsTabStop="False"
                        Focusable="False">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="24" Height="24">
                            <Path Data="M15.41 7.41L14 6L8 12L14 18L15.41 16.59L10.83 12Z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <TextBlock Grid.Column="1"
                           Text="俄罗斯方块"
                           FontSize="16" Margin="80 0 0 0"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SemiColorText0}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding RestartCommand}"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        IsVisible="{Binding IsPaused}"
                        IsTabStop="False"
                        Focusable="False">
                    <Panel>
                        <Viewbox Width="20" Height="20" IsVisible="{Binding IsPaused}">
                            <Canvas Width="24" Height="24">
                                 <Path Data="M12 5V2L8 6l4 4V7c3.31 0 6 2.69 6 6a6 6 0 0 1-6 6 6 6 0 0 1-6-6H4a8 8 0 0 0 8 8 8 8 0 0 0 8-8 8 8 0 0 0-8-8z"
                                       Fill="{DynamicResource SemiColorText0}"/>
                            </Canvas>
                        </Viewbox>
                    </Panel>
                </Button>

                <Button Grid.Column="3"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding TogglePauseCommand}"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        IsVisible="{Binding IsRunning}"
                        IsTabStop="False"
                        Focusable="False">
                    <Panel>
                        <Viewbox Width="20" Height="20" IsVisible="{Binding !IsPaused}">
                            <Canvas Width="24" Height="24">
                                <Rectangle Canvas.Left="5"  Canvas.Top="4" Width="4" Height="16"
                                           Fill="{DynamicResource SemiColorText0}" RadiusX="1" RadiusY="1"/>
                                <Rectangle Canvas.Left="15" Canvas.Top="4" Width="4" Height="16"
                                           Fill="{DynamicResource SemiColorText0}" RadiusX="1" RadiusY="1"/>
                            </Canvas>
                        </Viewbox>
                        <Viewbox Width="20" Height="20" IsVisible="{Binding IsPaused}">
                            <Canvas Width="24" Height="24">
                                <Path Data="M8 5v14l11-7z" Fill="{DynamicResource SemiColorText0}"/>
                            </Canvas>
                        </Viewbox>
                    </Panel>
                </Button>
            </Grid>
        </Border>

        <!-- ══ 游戏主区 ══ -->
        <Grid Grid.Row="1"
              ColumnDefinitions="90,*"
              Margin="0,6,0,4">

            <!-- 左侧信息栏 -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Top"
                        Margin="8,2,6,0"
                        Spacing="8">

                <Border Background="{DynamicResource SemiColorBg0}" CornerRadius="8" Padding="8,6">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="分数" FontSize="10" Foreground="{DynamicResource SemiColorText2}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Score}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SemiColorBg0}" CornerRadius="8" Padding="8,6">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="等级" FontSize="10" Foreground="{DynamicResource SemiColorText2}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Level}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SemiColorBg0}" CornerRadius="8" Padding="8,6">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="行数" FontSize="10" Foreground="{DynamicResource SemiColorText2}" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Lines}" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource SemiColorText0}" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SemiColorBg0}" CornerRadius="8" Padding="8,6">
                    <StackPanel HorizontalAlignment="Center" Spacing="4">
                        <TextBlock Text="NEXT" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SemiColorText2}" HorizontalAlignment="Center"/>
                      
                        <ItemsControl ItemsSource="{Binding PreviewCells}"
                                      Width="68" Height="68"
                                      HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="4" Columns="4"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CellViewModel">
                                    <Border Margin="1" CornerRadius="2" 
                                            Background="{Binding Type, Converter={StaticResource TypeToBrush}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SemiColorBg0}" CornerRadius="8" Padding="8,6">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="幽灵" FontSize="10" Foreground="{DynamicResource SemiColorText2}" HorizontalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding IsGhost}" Margin=" 0 5 0 0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1"
                    Margin="0,0,8,0"
                    CornerRadius="6"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    ClipToBounds="True"
                    x:Name="BoardBorder">
                <Panel>
                    <Viewbox Stretch="Fill">
                        <ItemsControl ItemsSource="{Binding Cells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="20" Columns="10"
                                                 Width="200" Height="400"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CellViewModel">
                                    <Border Margin="0.5" CornerRadius="2"
                                            Background="{Binding Type, Converter={StaticResource TypeToBrush}}"
                                            BorderThickness="0.5"
                                            BorderBrush="{DynamicResource SemiColorBorder}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Viewbox>

                    <!-- 游戏未开始遮罩 -->
                    <Border IsVisible="{Binding !IsRunning}" Background="#CC000000" CornerRadius="6">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">

                            <StackPanel IsVisible="{Binding IsGameOver}" HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="GAME OVER"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="#FF6B35"
                                           HorizontalAlignment="Center" LetterSpacing="2"/>
                                <TextBlock Text="{Binding Score, StringFormat='得分：{0}'}"
                                           FontSize="14" Foreground="#CCFFFFFF"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>

                            <TextBlock IsVisible="{Binding !IsGameOver}"
                                       Text="TETRIS"
                                       FontSize="28" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center" LetterSpacing="6"/>

                            <!-- Start (初始) -->
                            <Button IsVisible="{Binding !IsGameOver}"
                                    Command="{Binding StartCommand}"
                                    Content="开 始 游 戏"
                                    HorizontalAlignment="Center"
                                    Padding="28,12" CornerRadius="24"
                                    Background="#FF6B35" Foreground="White"
                                    FontWeight="SemiBold" FontSize="14" BorderThickness="0"
                                    IsTabStop="False" Focusable="False"/>

                            <!-- Restart (Game Over 后显示) -->
                            <Button IsVisible="{Binding IsGameOver}"
                                    Command="{Binding RestartCommand}"
                                    Content="重新开始"
                                    HorizontalAlignment="Center"
                                    Padding="28,12" CornerRadius="24"
                                    Background="#FF6B35" Foreground="White"
                                    FontWeight="SemiBold" FontSize="14" BorderThickness="0"
                                    IsTabStop="False" Focusable="False"/>
                        </StackPanel>
                    </Border>

                    <!-- 暂停遮罩 -->
                    <Border IsVisible="{Binding IsPaused}" Background="#AA000000" CornerRadius="6">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                            <TextBlock Text="⏸" FontSize="36" HorizontalAlignment="Center"/>
                            <TextBlock Text="已  暂  停"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center" LetterSpacing="4"/>
                            <TextBlock Text="按 P 或右上角继续"
                                       FontSize="12" Foreground="#AAFFFFFF" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Panel>
            </Border>
        </Grid>
      
        <Border Grid.Row="2"
                Background="{DynamicResource SemiColorBg0}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,1,0,0"
                Padding="10">

            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*,*,*,*">

                <!-- Row0 Col1：旋转 -->
                <RepeatButton Grid.Row="0" Grid.Column="1"
                        Command="{Binding RotateCommand}"
                        Classes="Success Warning" Theme="{DynamicResource SolidButton}"
                        CornerRadius="8"
                        IsTabStop="False" Focusable="False"
                        ToolTip.Tip="旋转 (↑/W)">
                    <Viewbox Width="40" Height="30">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 5V2L8 6l4 4V7c3.31 0 6 2.69 6 6a6 6 0 0 1-6 6 6 6 0 0 1-6-6H4a8 8 0 0 0 8 8 8 8 0 0 0 8-8 8 8 0 0 0-8-8z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </RepeatButton>

                <!-- Row0 Col3：硬降 -->
                <RepeatButton Grid.Row="0" Grid.Column="3"
                        Command="{Binding HardDropCommand}"
                        Classes="Success Warning" Theme="{DynamicResource SolidButton}"
                        CornerRadius="8"
                        IsTabStop="False" Focusable="False"
                        ToolTip.Tip="硬降 (空格)">
                    <Viewbox Width="40" Height="30">
                        <Canvas Width="24" Height="24">
                            <!-- 向下双箭头 -->
                            <Path Data="M7 10l5 5 5-5z" Fill="{DynamicResource SemiColorText0}"/>
                            <Path Data="M7 14l5 5 5-5z" Fill="{DynamicResource SemiColorText0}"/>
                            <Rectangle Canvas.Left="11" Canvas.Top="4" Width="2" Height="6"
                                       Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </RepeatButton>

                <!-- Row1 Col0：左移 -->
                <RepeatButton Grid.Row="1" Grid.Column="0"
                        Command="{Binding MoveLeftCommand}"
                        Classes="Success" Theme="{DynamicResource SolidButton}"
                        CornerRadius="8"
                        IsTabStop="False" Focusable="False"
                        ToolTip.Tip="左移 (←/A)">
                    <Viewbox Width="50" Height="40">
                        <Canvas Width="24" Height="24">
                            <Path Data="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </RepeatButton>

                <!-- Row1 Col2：软降 -->
                <RepeatButton Grid.Row="1" Grid.Column="2"
                        Command="{Binding SoftDropCommand}"
                        Classes="Success" Theme="{DynamicResource SolidButton}"
                        CornerRadius="8"
                        IsTabStop="False" Focusable="False"
                        ToolTip.Tip="加速 (↓/S)">
                    <Viewbox Width="50" Height="40">
                        <Canvas Width="24" Height="24">
                            <Path Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </RepeatButton>

                <!-- Row1 Col4：右移 -->
                <RepeatButton Grid.Row="1" Grid.Column="4"
                        Command="{Binding MoveRightCommand}"
                        Classes="Success" Theme="{DynamicResource SolidButton}"
                        CornerRadius="8"
                        IsTabStop="False" Focusable="False"
                        ToolTip.Tip="右移 (→/D)">
                    <Viewbox Width="50" Height="40">
                        <Canvas Width="24" Height="24">
                            <Path Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </RepeatButton>
            </Grid>
        </Border>
    </Grid>

</UserControl>