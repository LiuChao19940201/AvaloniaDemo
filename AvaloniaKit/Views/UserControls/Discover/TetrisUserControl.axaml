<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:AvaloniaKit.ViewModels.UserControls.Discover"
             xmlns:converters="clr-namespace:AvaloniaKit.Converters"
             x:Class="AvaloniaKit.Views.UserControls.Discover.TetrisUserControl"
             d:DesignWidth="390" d:DesignHeight="760"
             x:DataType="vm:TetrisViewModel">

    <Design.DataContext>
        <vm:TetrisViewModel/>
    </Design.DataContext>

    <UserControl.Resources>
        <!-- ─── 颜色资源 ─── -->
        <SolidColorBrush x:Key="TypeI_Brush"     Color="#00BCD4"/>
        <SolidColorBrush x:Key="TypeO_Brush"     Color="#FFD600"/>
        <SolidColorBrush x:Key="TypeT_Brush"     Color="#AB47BC"/>
        <SolidColorBrush x:Key="TypeS_Brush"     Color="#66BB6A"/>
        <SolidColorBrush x:Key="TypeZ_Brush"     Color="#EF5350"/>
        <SolidColorBrush x:Key="TypeJ_Brush"     Color="#42A5F5"/>
        <SolidColorBrush x:Key="TypeL_Brush"     Color="#FF7043"/>
        <SolidColorBrush x:Key="TypeGhost_Brush" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="TypeEmpty_Brush" Color="#0DFFFFFF"/>

        <!-- ─── Converter: TetrominoType → Brush ─── -->
        <converters:TetrominoTypeToBrushConverter x:Key="TypeToBrush"/>
    </UserControl.Resources>

    <!--
    ┌─────────────────────────────────────────────────┐
    │  外层：三行布局 导航栏 / 游戏区 / 触摸控制栏      │
    └─────────────────────────────────────────────────┘
    -->
    <Grid RowDefinitions="Auto,*,Auto"
          Background="{DynamicResource SemiColorBg1}">

        <!-- ══ 顶部导航栏 ══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SemiColorBg0}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,0,0,0.8"
                Padding="0,8">
            <Grid ColumnDefinitions="44,*,44">

                <!-- 返回按钮 -->
                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding GoBackCommand}"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="24" Height="24">
                            <Path Data="M15.41 7.41L14 6L8 12L14 18L15.41 16.59L10.83 12Z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <!-- 标题（与返回按钮垂直居中对齐） -->
                <TextBlock Grid.Column="1"
                           Text="俄罗斯方块"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SemiColorText0}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- 暂停按钮 -->
                <Button Grid.Column="2"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding TogglePauseCommand}"
                        Padding="12,8"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsRunning}">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="24" Height="24">
                            <!-- 暂停图标（两条竖线） -->
                            <Rectangle Canvas.Left="5"  Canvas.Top="4" Width="4" Height="16"
                                       Fill="{DynamicResource SemiColorText0}"
                                       RadiusX="1" RadiusY="1"/>
                            <Rectangle Canvas.Left="15" Canvas.Top="4" Width="4" Height="16"
                                       Fill="{DynamicResource SemiColorText0}"
                                       RadiusX="1" RadiusY="1"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
        </Border>

        <!-- ══ 游戏区 ══ -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,12"
              Margin="0,8">

            <!-- 评分侧边栏 -->
            <StackPanel Grid.Column="0"
                        VerticalAlignment="Top"
                        Margin="12,0,8,0"
                        Spacing="12">

                <!-- 分数 -->
                <Border Background="{DynamicResource SemiColorBg0}"
                        CornerRadius="10"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="分数"
                                   FontSize="11"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Score}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SemiColorText0}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 等级 -->
                <Border Background="{DynamicResource SemiColorBg0}"
                        CornerRadius="10"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="等级"
                                   FontSize="11"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Level}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SemiColorText0}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 行数 -->
                <Border Background="{DynamicResource SemiColorBg0}"
                        CornerRadius="10"
                        Padding="10,8">
                    <StackPanel>
                        <TextBlock Text="行数"
                                   FontSize="11"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding Lines}"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SemiColorText0}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 下一个预览 -->
                <Border Background="{DynamicResource SemiColorBg0}"
                        CornerRadius="10"
                        Padding="8">
                    <StackPanel>
                        <TextBlock Text="NEXT"
                                   FontSize="11"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,6"/>
                        <!-- 4×4 预览格 -->
                        <ItemsControl ItemsSource="{Binding PreviewCells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Rows="4" Columns="4"
                                                 Width="72" Height="72"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:CellViewModel">
                                    <Border Margin="1"
                                            CornerRadius="2"
                                            Background="{Binding Type, Converter={StaticResource TypeToBrush}}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── 主游戏板 ── -->
            <Border Grid.Column="1"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource SemiColorBorder}"
                    BorderThickness="1"
                    ClipToBounds="True">

                <!-- 游戏板 20×10 -->
                <Panel>
                    <ItemsControl ItemsSource="{Binding Cells}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="20" Columns="10"
                                             Width="200" Height="400"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:CellViewModel">
                                <Border Margin="0.5"
                                        CornerRadius="2"
                                        Background="{Binding Type, Converter={StaticResource TypeToBrush}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 游戏未开始遮罩 -->
                    <Border IsVisible="{Binding !IsRunning}"
                            Background="#AA000000"
                            CornerRadius="8">
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Spacing="16">

                            <!-- GAME OVER 标题 -->
                            <TextBlock IsVisible="{Binding IsGameOver}"
                                       Text="GAME OVER"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <!-- 首次进入标题 -->
                            <TextBlock IsVisible="{Binding !IsGameOver}"
                                       Text="TETRIS"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>

                            <!-- 开始按钮（首次） -->
                            <Button IsVisible="{Binding !IsGameOver}"
                                    Command="{Binding StartCommand}"
                                    Content="开 始"
                                    HorizontalAlignment="Center"
                                    Padding="32,12"
                                    CornerRadius="24"
                                    Background="#FF6B35"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    FontSize="15"/>

                            <!-- 再玩一局按钮（Game Over 后） -->
                            <Button IsVisible="{Binding IsGameOver}"
                                    Command="{Binding RestartCommand}"
                                    Content="再玩一局"
                                    HorizontalAlignment="Center"
                                    Padding="32,12"
                                    CornerRadius="24"
                                    Background="#FF6B35"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    FontSize="15"/>
                        </StackPanel>
                    </Border>

                    <!-- 暂停遮罩 -->
                    <Border IsVisible="{Binding IsPaused}"
                            Background="#AA000000"
                            CornerRadius="8">
                        <TextBlock Text="已暂停"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Panel>
            </Border>
        </Grid>

        <!-- ══ 触摸控制区（移动设备显示，桌面端键盘控制） ══ -->
        <Border Grid.Row="2"
                Background="{DynamicResource SemiColorBg0}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,0.8,0,0"
                Padding="8,12,8,24">

            <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="Auto,Auto">

                <!-- Row 0: 旋转 + 硬降 -->
                <Button Grid.Row="0" Grid.Column="1"
                        Command="{Binding RotateCommand}"
                        Classes="ctrl-btn"
                        ToolTip.Tip="旋转 (↑)">
                    <!-- 旋转图标 -->
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 6V3L8 7l4 4V8c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Grid.Row="0" Grid.Column="3"
                        Command="{Binding HardDropCommand}"
                        Classes="ctrl-btn"
                        ToolTip.Tip="硬降 (空格)">
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="24" Height="24">
                            <Path Data="M20 5H4v2l8 9 8-9V5zm-8 13l-8-9v9h16v-9l-8 9z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <!-- Row 1: 左 / 下 / 右 -->
                <Button Grid.Row="1" Grid.Column="0"
                        Command="{Binding MoveLeftCommand}"
                        Classes="ctrl-btn"
                        ToolTip.Tip="左移 (←)">
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="24" Height="24">
                            <Path Data="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Grid.Row="1" Grid.Column="2"
                        Command="{Binding SoftDropCommand}"
                        Classes="ctrl-btn"
                        ToolTip.Tip="加速下落 (↓)">
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="24" Height="24">
                            <Path Data="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </Button>

                <Button Grid.Row="1" Grid.Column="4"
                        Command="{Binding MoveRightCommand}"
                        Classes="ctrl-btn"
                        ToolTip.Tip="右移 (→)">
                    <Viewbox Width="22" Height="22">
                        <Canvas Width="24" Height="24">
                            <Path Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </Button>
            </Grid>
        </Border>
    </Grid>

    <UserControl.Styles>
        <Style Selector="Button.ctrl-btn">
            <Setter Property="Width"           Value="56"/>
            <Setter Property="Height"          Value="56"/>
            <Setter Property="CornerRadius"    Value="28"/>
            <Setter Property="Background"      Value="{DynamicResource SemiColorBg2}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin"          Value="4,6"/>
        </Style>
        <Style Selector="Button.ctrl-btn:pressed">
            <Setter Property="Background" Value="{DynamicResource SemiColorPrimary}"/>
            <Setter Property="RenderTransform" Value="scale(0.92)"/>
        </Style>

        <!-- 开始/再玩 按钮 -->
        <Style Selector="Button.start-btn">
            <Setter Property="Background" Value="#FF6B35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="24,10"/>
        </Style>
    </UserControl.Styles>
</UserControl>
