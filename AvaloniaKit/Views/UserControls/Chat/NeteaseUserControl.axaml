<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:AvaloniaKit.ViewModels.UserControls.Chat"
			 mc:Ignorable="d"
			 d:DesignWidth="390" d:DesignHeight="760"
			 x:Class="AvaloniaKit.Views.UserControls.Chat.NeteaseUserControl"
			 x:DataType="vm:NeteaseViewModel">
	<Design.DataContext>
		<vm:NeteaseViewModel />
	</Design.DataContext>
	<UserControl.Styles>
		<Style Selector="Button.tab-btn">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Foreground"      Value="{DynamicResource SemiColorText2}"/>
			<Setter Property="FontSize"        Value="15"/>
			<Setter Property="Padding"         Value="0,10"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
		</Style>
		<Style Selector="Button.tab-btn.active">
			<Setter Property="Foreground" Value="#E05C5C"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		<Style Selector="Button.tab-btn:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<Style Selector="Button.rank-btn">
			<Setter Property="Background"      Value="{DynamicResource SemiColorFillQuaternary}"/>
			<Setter Property="Foreground"      Value="{DynamicResource SemiColorText1}"/>
			<Setter Property="FontSize"        Value="12"/>
			<Setter Property="Padding"         Value="14,5"/>
			<Setter Property="CornerRadius"    Value="14"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="MinHeight"       Value="0"/>
		</Style>
		<Style Selector="Button.rank-btn.active">
			<Setter Property="Background" Value="#E05C5C"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
		</Style>
		<Style Selector="Button.rank-btn:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="{DynamicResource SemiColorFillTertiary}"/>
		</Style>
		<Style Selector="Button.rank-btn.active:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="#E05C5C"/>
		</Style>
		<Style Selector="Button.icon-btn">
			<Setter Property="Background"      Value="Transparent"/>
			<Setter Property="Padding"         Value="8"/>
			<Setter Property="BorderThickness" Value="0"/>
		</Style>
		<Style Selector="Button.icon-btn:pointerover /template/ ContentPresenter">
			<Setter Property="Background" Value="Transparent"/>
		</Style>
		<!-- 封面缩略图统一样式 -->
		<Style Selector="Border.cover-thumb">
			<Setter Property="Width"        Value="44"/>
			<Setter Property="Height"       Value="44"/>
			<Setter Property="CornerRadius" Value="6"/>
			<Setter Property="ClipToBounds" Value="True"/>
			<Setter Property="Background"   Value="{DynamicResource SemiColorFillTertiary}"/>
			<Setter Property="VerticalAlignment" Value="Center"/>
		</Style>
	</UserControl.Styles>

	<DockPanel Background="{DynamicResource SemiColorBg1}">
		<!-- 顶部导航 -->
		<Border DockPanel.Dock="Top"
				Background="{DynamicResource SemiColorBg0}"
				BorderBrush="{DynamicResource SemiColorBorder}"
				BorderThickness="0,0,0,0.8"
				Padding="4,8">
			<Grid ColumnDefinitions="44,*,44">
				<Button Grid.Column="0" Classes="icon-btn"
						Command="{Binding GoBackCommand}"
						HorizontalAlignment="Center" VerticalAlignment="Center">
					<Viewbox Width="20" Height="20">
						<Canvas Width="24" Height="24">
							<Path Data="M20 11H7.83L13.42 5.41 12 4 4 12 12 20 13.41 18.59 7.83 13H20V11Z"
								  Fill="{DynamicResource SemiColorText0}"/>
						</Canvas>
					</Viewbox>
				</Button>
				<StackPanel Grid.Column="1" Orientation="Horizontal"
							HorizontalAlignment="Center" Spacing="4">
					<Button Classes="tab-btn" Classes.active="{Binding IsRecommendActive}"
							Content="推荐" Command="{Binding SwitchRecommendCommand}"/>
					<TextBlock Text="|" VerticalAlignment="Center"
							   Foreground="{DynamicResource SemiColorBorder}" FontSize="14"/>
					<Button Classes="tab-btn" Classes.active="{Binding IsRankActive}"
							Content="排行榜" Command="{Binding SwitchRankCommand}"/>
					<TextBlock Text="|" VerticalAlignment="Center"
							   Foreground="{DynamicResource SemiColorBorder}" FontSize="14"/>
					<Button Classes="tab-btn" Classes.active="{Binding IsSearchActive}"
							Content="搜索" Command="{Binding SwitchSearchCommand}"/>
				</StackPanel>
				<Button Grid.Column="2" Classes="icon-btn"
						Command="{Binding SwitchSearchCommand}"
						HorizontalAlignment="Center" VerticalAlignment="Center">
					<Viewbox Width="20" Height="20">
						<Canvas Width="24" Height="24">
							<Path Data="M15.5 14H14.71L14.43 13.73C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16C11.11 16 12.59 15.41 13.73 14.43L14 14.71V15.5L19 20.49 20.49 19 15.5 14ZM9.5 14C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14Z"
								  Fill="{DynamicResource SemiColorText0}"/>
						</Canvas>
					</Viewbox>
				</Button>
			</Grid>
		</Border>

		<!-- 迷你播放栏 -->
		<Border DockPanel.Dock="Bottom"
				IsVisible="{Binding HasCurrentSong}"
				Background="{DynamicResource SemiColorBg0}"
				BorderBrush="{DynamicResource SemiColorBorder}"
				BorderThickness="0,0.8,0,0">
			<Button Background="Transparent"
					HorizontalAlignment="Stretch"
					HorizontalContentAlignment="Stretch"
					Padding="16,10"
					Command="{Binding OpenPlayerCommand}">
				<Grid ColumnDefinitions="46,*,Auto,Auto">
					<!-- ★ 封面绑定 CoverBitmap（Bitmap类型，不再是字符串）-->
					<Border Grid.Column="0" Classes="cover-thumb" Width="40" Height="40">
						<Panel>
							<Image Source="{Binding CurrentSong.CoverBitmap}"
								   Stretch="UniformToFill"
								   IsVisible="{Binding CurrentSong.HasCover}"/>
							<Viewbox Width="20" Height="20"
									 HorizontalAlignment="Center" VerticalAlignment="Center"
									 IsVisible="{Binding !CurrentSong.HasCover}">
								<Canvas Width="24" Height="24">
									<Path Data="M12 3V13.55C11.41 13.21 10.73 13 10 13C7.79 13 6 14.79 6 17S7.79 21 10 21 14 19.21 14 17V7H18V3H12Z"
										  Fill="{DynamicResource SemiColorText2}"/>
								</Canvas>
							</Viewbox>
						</Panel>
					</Border>
					<StackPanel Grid.Column="1" VerticalAlignment="Center"
								Margin="0,0,8,0" Spacing="2">
						<TextBlock Text="{Binding CurrentSong.Name}"
								   FontSize="14" FontWeight="SemiBold"
								   Foreground="{DynamicResource SemiColorText0}"
								   TextTrimming="CharacterEllipsis"/>
						<TextBlock Text="{Binding CurrentSong.Artist}"
								   FontSize="12"
								   Foreground="{DynamicResource SemiColorText2}"
								   TextTrimming="CharacterEllipsis"/>
					</StackPanel>
					<Button Grid.Column="2" Classes="icon-btn"
							Command="{Binding OpenPlayerCommand}"
							VerticalAlignment="Center">
						<Viewbox Width="24" Height="24">
							<Canvas Width="24" Height="24">
								<Path Data="{Binding PlayBtnIcon}"
									  Fill="{DynamicResource SemiColorText0}"/>
							</Canvas>
						</Viewbox>
					</Button>
					<Viewbox Grid.Column="3" Width="16" Height="16"
							 VerticalAlignment="Center" Margin="4,0,0,0">
						<Canvas Width="24" Height="24">
							<Path Data="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41Z"
								  Fill="{DynamicResource SemiColorText2}"/>
						</Canvas>
					</Viewbox>
				</Grid>
			</Button>
		</Border>

		<!-- 主内容 -->
		<Panel>
			<!-- 推荐 Tab -->
			<DockPanel IsVisible="{Binding IsRecommendActive}">
				<Border DockPanel.Dock="Top"
						Background="{DynamicResource SemiColorBg0}"
						BorderBrush="{DynamicResource SemiColorBorder}"
						BorderThickness="0,0,0,0.4"
						Padding="16,8">
					<TextBlock Text="{Binding StatusText}" FontSize="12"
							   Foreground="{DynamicResource SemiColorText2}"/>
				</Border>
				<Border DockPanel.Dock="Top" IsVisible="{Binding IsRecommendLoading}" Padding="0,20">
					<TextBlock Text="加载中…" FontSize="14"
							   Foreground="{DynamicResource SemiColorText2}"
							   HorizontalAlignment="Center"/>
				</Border>
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<ItemsControl ItemsSource="{Binding RecommendSongs}"
								  Background="{DynamicResource SemiColorBg0}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="vm:NeteaseSongItem">
								<StackPanel>
									<Button Background="Transparent"
											HorizontalAlignment="Stretch"
											HorizontalContentAlignment="Stretch"
											Padding="0"
											Command="{Binding $parent[ItemsControl].((vm:NeteaseViewModel)DataContext).PlaySongCommand}"
											CommandParameter="{Binding}">
										<Grid ColumnDefinitions="56,*,Auto" Margin="16,0" MinHeight="62">
											<!-- ★ 封面 -->
											<Border Grid.Column="0" Classes="cover-thumb">
												<Panel>
													<Image Source="{Binding CoverBitmap}"
														   Stretch="UniformToFill"
														   IsVisible="{Binding HasCover}"/>
													<Viewbox Width="22" Height="22"
															 HorizontalAlignment="Center" VerticalAlignment="Center"
															 IsVisible="{Binding !HasCover}">
														<Canvas Width="24" Height="24">
															<Path Data="M12 3V13.55C11.41 13.21 10.73 13 10 13C7.79 13 6 14.79 6 17S7.79 21 10 21 14 19.21 14 17V7H18V3H12Z"
																  Fill="{DynamicResource SemiColorText2}"/>
														</Canvas>
													</Viewbox>
												</Panel>
											</Border>
											<StackPanel Grid.Column="1" VerticalAlignment="Center"
														Margin="0,0,8,0" Spacing="3">
												<TextBlock Text="{Binding Name}" FontSize="15"
														   Foreground="{DynamicResource SemiColorText0}"
														   TextTrimming="CharacterEllipsis"/>
												<TextBlock FontSize="12"
														   Foreground="{DynamicResource SemiColorText2}"
														   TextTrimming="CharacterEllipsis">
													<Run Text="{Binding Artist}"/>
													<Run Text=" - "/>
													<Run Text="{Binding Album}"/>
												</TextBlock>
											</StackPanel>
											<TextBlock Grid.Column="2" Text="{Binding DurationText}"
													   FontSize="12" Foreground="{DynamicResource SemiColorText2}"
													   VerticalAlignment="Center"/>
										</Grid>
									</Button>
									<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="72,0,0,0"/>
								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</DockPanel>

			<!-- 排行榜 Tab -->
			<DockPanel IsVisible="{Binding IsRankActive}">
				<Border DockPanel.Dock="Top"
						Background="{DynamicResource SemiColorBg0}"
						BorderBrush="{DynamicResource SemiColorBorder}"
						BorderThickness="0,0,0,0.6"
						Padding="16,10">
					<ItemsControl ItemsSource="{Binding RankCategories}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Horizontal" Spacing="8"/>
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<Button Classes="rank-btn"
										Classes.active="{Binding IsSelected}"
										Content="{Binding Name}"
										Command="{Binding $parent[ItemsControl].((vm:NeteaseViewModel)DataContext).SelectRankCommand}"
										CommandParameter="{Binding Index}" />
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</Border>
				<Border DockPanel.Dock="Top" IsVisible="{Binding IsRankLoading}" Padding="0,20">
					<TextBlock Text="加载中…" FontSize="14"
							   Foreground="{DynamicResource SemiColorText2}"
							   HorizontalAlignment="Center"/>
				</Border>
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<ItemsControl ItemsSource="{Binding RankSongs}"
								  Background="{DynamicResource SemiColorBg0}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="vm:NeteaseSongItem">
								<StackPanel>
									<Button Background="Transparent"
											HorizontalAlignment="Stretch"
											HorizontalContentAlignment="Stretch"
											Padding="0"
											Command="{Binding $parent[ItemsControl].((vm:NeteaseViewModel)DataContext).PlaySongCommand}"
											CommandParameter="{Binding}">
										<Grid ColumnDefinitions="56,*,Auto" Margin="16,0" MinHeight="62">
											<Border Grid.Column="0" Classes="cover-thumb">
												<Panel>
													<Image Source="{Binding CoverBitmap}"
														   Stretch="UniformToFill"
														   IsVisible="{Binding HasCover}"/>
													<Viewbox Width="22" Height="22"
															 HorizontalAlignment="Center" VerticalAlignment="Center"
															 IsVisible="{Binding !HasCover}">
														<Canvas Width="24" Height="24">
															<Path Data="M12 3V13.55C11.41 13.21 10.73 13 10 13C7.79 13 6 14.79 6 17S7.79 21 10 21 14 19.21 14 17V7H18V3H12Z"
																  Fill="{DynamicResource SemiColorText2}"/>
														</Canvas>
													</Viewbox>
												</Panel>
											</Border>
											<StackPanel Grid.Column="1" VerticalAlignment="Center"
														Margin="0,0,8,0" Spacing="3">
												<TextBlock Text="{Binding Name}" FontSize="15"
														   Foreground="{DynamicResource SemiColorText0}"
														   TextTrimming="CharacterEllipsis"/>
												<TextBlock FontSize="12"
														   Foreground="{DynamicResource SemiColorText2}"
														   TextTrimming="CharacterEllipsis">
													<Run Text="{Binding Artist}"/>
													<Run Text=" - "/>
													<Run Text="{Binding Album}"/>
												</TextBlock>
											</StackPanel>
											<TextBlock Grid.Column="2" Text="{Binding DurationText}"
													   FontSize="12" Foreground="{DynamicResource SemiColorText2}"
													   VerticalAlignment="Center"/>
										</Grid>
									</Button>
									<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="72,0,0,0"/>
								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</DockPanel>

			<!-- 搜索 Tab -->
			<DockPanel IsVisible="{Binding IsSearchActive}">
				<Border DockPanel.Dock="Top"
						Background="{DynamicResource SemiColorBg0}"
						BorderBrush="{DynamicResource SemiColorBorder}"
						BorderThickness="0,0,0,0.8"
						Padding="12,10">
					<Grid ColumnDefinitions="*,Auto">
						<TextBox Grid.Column="0"
								 Text="{Binding SearchKeyword}"
								 Watermark="搜索歌曲、歌手…"
								 FontSize="14" Padding="12,9"
								 CornerRadius="20 0 0 20">
							<TextBox.KeyBindings>
								<KeyBinding Gesture="Return" Command="{Binding SearchCommand}"/>
							</TextBox.KeyBindings>
						</TextBox>
						<Button Grid.Column="1" Content="搜索"
								Command="{Binding SearchCommand}"
								IsEnabled="{Binding !IsSearchLoading}"
								Padding="16,9" FontSize="14"
								CornerRadius="0 20 20 0"
								Background="#E05C5C" Foreground="White"/>
					</Grid>
				</Border>
				<TextBlock DockPanel.Dock="Top"
						   Text="{Binding SearchStatus}"
						   IsVisible="{Binding SearchStatus.Length}"
						   FontSize="12" Foreground="{DynamicResource SemiColorText2}"
						   Margin="16,8"/>
				<ScrollViewer VerticalScrollBarVisibility="Auto">
					<Panel>
						<Border IsVisible="{Binding !SearchResults.Count}" Padding="0,60">
							<StackPanel HorizontalAlignment="Center" Spacing="12">
								<Viewbox Width="52" Height="52" HorizontalAlignment="Center">
									<Canvas Width="24" Height="24">
										<Path Data="M15.5 14H14.71L14.43 13.73C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16C11.11 16 12.59 15.41 13.73 14.43L14 14.71V15.5L19 20.49 20.49 19 15.5 14ZM9.5 14C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14Z"
											  Fill="{DynamicResource SemiColorBorder}"/>
									</Canvas>
								</Viewbox>
								<TextBlock Text="输入关键词搜索歌曲" FontSize="15"
										   Foreground="{DynamicResource SemiColorText2}"
										   HorizontalAlignment="Center"/>
							</StackPanel>
						</Border>
						<ItemsControl ItemsSource="{Binding SearchResults}"
									  Background="{DynamicResource SemiColorBg0}"
									  IsVisible="{Binding SearchResults.Count}">
							<ItemsControl.ItemTemplate>
								<DataTemplate x:DataType="vm:NeteaseSongItem">
									<StackPanel>
										<Button Background="Transparent"
												HorizontalAlignment="Stretch"
												HorizontalContentAlignment="Stretch"
												Padding="0"
												Command="{Binding $parent[ItemsControl].((vm:NeteaseViewModel)DataContext).PlaySongCommand}"
												CommandParameter="{Binding}">
											<Grid ColumnDefinitions="56,*,Auto" Margin="16,0" MinHeight="62">
												<Border Grid.Column="0" Classes="cover-thumb">
													<Panel>
														<Image Source="{Binding CoverBitmap}"
															   Stretch="UniformToFill"
															   IsVisible="{Binding HasCover}"/>
														<Viewbox Width="22" Height="22"
																 HorizontalAlignment="Center" VerticalAlignment="Center"
																 IsVisible="{Binding !HasCover}">
															<Canvas Width="24" Height="24">
																<Path Data="M12 3V13.55C11.41 13.21 10.73 13 10 13C7.79 13 6 14.79 6 17S7.79 21 10 21 14 19.21 14 17V7H18V3H12Z"
																	  Fill="{DynamicResource SemiColorText2}"/>
															</Canvas>
														</Viewbox>
													</Panel>
												</Border>
												<StackPanel Grid.Column="1" VerticalAlignment="Center"
															Margin="0,0,8,0" Spacing="3">
													<TextBlock Text="{Binding Name}" FontSize="15"
															   Foreground="{DynamicResource SemiColorText0}"
															   TextTrimming="CharacterEllipsis"/>
													<TextBlock FontSize="12"
															   Foreground="{DynamicResource SemiColorText2}"
															   TextTrimming="CharacterEllipsis">
														<Run Text="{Binding Artist}"/>
														<Run Text=" - "/>
														<Run Text="{Binding Album}"/>
													</TextBlock>
												</StackPanel>
												<TextBlock Grid.Column="2" Text="{Binding DurationText}"
														   FontSize="12" Foreground="{DynamicResource SemiColorText2}"
														   VerticalAlignment="Center"/>
											</Grid>
										</Button>
										<Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="72,0,0,0"/>
									</StackPanel>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Panel>
				</ScrollViewer>
			</DockPanel>
		</Panel>
	</DockPanel>
</UserControl>
