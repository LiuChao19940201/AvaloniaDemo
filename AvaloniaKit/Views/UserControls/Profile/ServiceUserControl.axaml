<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:profileVm="using:AvaloniaKit.ViewModels.UserControls.Profile"
             mc:Ignorable="d"
             d:DesignWidth="350" d:DesignHeight="700"
             x:CompileBindings="True"
             x:DataType="profileVm:ServiceViewModel"
             x:Class="AvaloniaKit.Views.UserControls.Profile.ServiceUserControl">

    <Design.DataContext>
        <profileVm:ServiceViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource SemiColorBg1}">

        <!-- ══ 顶部导航栏（含返回箭头） ══ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SemiColorBg0}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,0,0,0.8"
                Padding="0,8">
            <Grid ColumnDefinitions="44,*,44">
                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding GoBackCommand}"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <Viewbox Width="20" Height="20">
                        <Canvas Width="24" Height="24">
                            <Path Data="M15.41 7.41L14 6L8 12L14 18L15.41 16.59L10.83 12Z"
                                  Fill="{DynamicResource SemiColorText0}"/>
                        </Canvas>
                    </Viewbox>
                </Button>
                <TextBlock Grid.Column="1" Text="服务"
                           FontSize="17" FontWeight="SemiBold"
                           Foreground="{DynamicResource SemiColorText0}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Panel Grid.Column="2"/>
            </Grid>
        </Border>

        <!-- ══ 滚动内容 ══ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- ── 设备硬件 ── -->
                <TextBlock Text="设备硬件" FontSize="13" Margin="16,12,0,6"
                           Foreground="{DynamicResource SemiColorText2}"/>
                <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                    <StackPanel>

                        <!-- 打开相机 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding OpenCameraCommand}">
                            <Grid ColumnDefinitions="56,*">           <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12 15.2C13.77 15.2 15.2 13.77 15.2 12C15.2 10.23 13.77 8.8 12 8.8C10.23 8.8 8.8 10.23 8.8 12C8.8 13.77 10.23 15.2 12 15.2ZM9 2L7.17 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V6C22 4.9 21.1 4 20 4H16.83L15 2H9ZM12 17C9.24 17 7 14.76 7 12C7 9.24 9.24 7 12 7C14.76 7 17 9.24 17 12C17 14.76 14.76 17 12 17Z"
                                              Fill="#07C160"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="打开相机" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- 震动测试 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding VibrateCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M0 15H2V9H0V15ZM3 17H5V7H3V17ZM22 9V15H24V9H22ZM19 17H21V7H19V17ZM16.5 3H7.5C6.67 3 6 3.67 6 4.5V19.5C6 20.33 6.67 21 7.5 21H16.5C17.33 21 18 20.33 18 19.5V4.5C18 3.67 17.33 3 16.5 3ZM16 17H8V7H16V17Z"
                                              Fill="#FF6B6B"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="震动测试" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- 打开相册 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding OpenAlbumCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M21 19V5C21 3.9 20.1 3 19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19ZM8.5 13.5L11 16.51L14.5 12L19 18H5L8.5 13.5Z"
                                              Fill="#3498DB"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="打开相册" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- 音效测试 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding PlaySoundCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12 3V12.26C11.47 12.1 10.92 12 10.36 12C7.95 12 6 13.79 6 16C6 18.21 7.95 20 10.36 20C12.77 20 14.72 18.21 14.72 16V6H18V3H12Z"
                                              Fill="#F1C40F"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="音效测试" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ── 无线连接 ── -->
                <TextBlock Text="无线连接" FontSize="13" Margin="16,4,0,6"
                           Foreground="{DynamicResource SemiColorText2}"/>
                <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                    <StackPanel>

                        <!-- 蓝牙测试 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding TestBluetoothCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M17.71 7.71L12 2H11V9.59L6.41 5L5 6.41L10.59 12L5 17.59L6.41 19L11 14.41V22H12L17.71 16.29L13.41 12L17.71 7.71ZM13 5.83L14.88 7.71L13 9.59V5.83ZM14.88 16.29L13 18.17V14.41L14.88 16.29Z"
                                              Fill="#3498DB"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="蓝牙测试" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- GPS 定位 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding TestGpsCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12 2C8.13 2 5 5.13 5 9C5 14.25 12 22 12 22C12 22 19 14.25 19 9C19 5.13 15.87 2 12 2ZM12 11.5C10.62 11.5 9.5 10.38 9.5 9C9.5 7.62 10.62 6.5 12 6.5C13.38 6.5 14.5 7.62 14.5 9C14.5 10.38 13.38 11.5 12 11.5Z"
                                              Fill="#E74C3C"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="GPS 定位" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- NFC 测试 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding TestNfcCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M20 2H4C2.9 2 2 2.9 2 4V20C2 21.1 2.9 22 4 22H20C21.1 22 22 21.1 22 20V4C22 2.9 21.1 2 20 2ZM4 20V4H8.5C7.57 4.78 7 5.82 7 7V17H9V7C9 5.9 9.9 5 11 5H13C14.1 5 15 5.9 15 7V17H17V7C17 5.82 16.43 4.78 15.5 4H20V20H4Z"
                                              Fill="#9B59B6"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="NFC 测试" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- WiFi 测试 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding TestWifiCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M1 9L3 11C7.97 6.03 16.03 6.03 21 11L23 9C17.16 3.16 6.84 3.16 1 9ZM9 17L12 20L15 17C13.35 15.34 10.66 15.34 9 17ZM5 13L7 15C9.76 12.24 14.24 12.24 17 15L19 13C15.14 9.14 8.87 9.14 5 13Z"
                                              Fill="#2ECC71"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="WiFi 测试" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ── 其他测试 ── -->
                <TextBlock Text="其他测试" FontSize="13" Margin="16,4,0,6"
                           Foreground="{DynamicResource SemiColorText2}"/>
                <Border Background="{DynamicResource SemiColorBg0}" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="0,0.5,0,0.5">
                    <StackPanel>

                        <!-- 闪光灯 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding TestFlashlightCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M9 21C9 21.55 9.45 22 10 22H14C14.55 22 15 21.55 15 21V20H9V21ZM12 2C8.14 2 5 5.14 5 9C5 11.38 6.19 13.47 8 14.74V17C8 17.55 8.45 18 9 18H15C15.55 18 16 17.55 16 17V14.74C17.81 13.47 19 11.38 19 9C19 5.14 15.86 2 12 2Z"
                                              Fill="#FA8C16"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="闪光灯" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- 屏幕亮度 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding TestBrightnessCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M20 8.69V4H15.31L12 0.69L8.69 4H4V8.69L0.69 12L4 15.31V20H8.69L12 23.31L15.31 20H20V15.31L23.31 12L20 8.69ZM12 18C8.69 18 6 15.31 6 12C6 8.69 8.69 6 12 6C15.31 6 18 8.69 18 12C18 15.31 15.31 18 12 18ZM12 8C9.79 8 8 9.79 8 12C8 14.21 9.79 16 12 16C14.21 16 16 14.21 16 12C16 9.79 14.21 8 12 8Z"
                                              Fill="#FF8C00"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="屏幕亮度" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- 传感器 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding TestSensorCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 20C7.58 20 4 16.42 4 12C4 7.58 7.58 4 12 4C16.42 4 20 7.58 20 12C20 16.42 16.42 20 12 20ZM12.5 7H11V13L16.25 16.15L17 14.92L12.5 12.25V7Z"
                                              Fill="#8E44AD"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="传感器" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                        <Rectangle Height="0.6" Fill="{DynamicResource SemiColorBorder}" Margin="56,0,0,0"/>

                        <!-- 通知推送 -->
                        <Button Background="Transparent" HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch" Height="52" Padding="0"
                                Command="{Binding TestNotificationCommand}">
                            <Grid ColumnDefinitions="56,*">
                                <Viewbox Grid.Column="0" Width="24" Height="24"
                                         HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M12 22C13.1 22 14 21.1 14 20H10C10 21.1 10.9 22 12 22ZM18 16V11C18 7.93 16.36 5.36 13.5 4.68V4C13.5 3.17 12.83 2.5 12 2.5C11.17 2.5 10.5 3.17 10.5 4V4.68C7.63 5.36 6 7.92 6 11V16L4 18V19H20V18L18 16Z"
                                              Fill="#E67E22"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="通知推送" FontSize="16"
                                           Foreground="{DynamicResource SemiColorText0}" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══ 底部状态提示栏 ══ -->
        <Border Grid.Row="2"
                Background="{DynamicResource SemiColorBg0}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,0.8,0,0"
                Padding="16,10"
                IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="14"
                       Foreground="{DynamicResource SemiColorText1}"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>