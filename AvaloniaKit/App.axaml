<Application xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:local="using:AvaloniaKit"
			 x:Class="AvaloniaKit.App"
			 xmlns:semi="https://irihi.tech/semi"
			 xmlns:cvt="using:AvaloniaKit.Tools.Converters"
			 xmlns:u-semi="https://irihi.tech/ursa/themes/semi"
			 RequestedThemeVariant="Default">
	
	<Application.Resources>
		<ResourceDictionary>
			<cvt:BoolToTabColorConverter x:Key="BoolToTabColorConverter" />
		</ResourceDictionary>
	</Application.Resources>

	<Application.Styles>
		<semi:SemiTheme Locale="zh-cn" />
		<u-semi:SemiTheme Locale="zh-CN"/>
		<semi:SemiPopupAnimations />

		<!--控件缩放-->
		<Style Selector="Button:pointerover,Border#border1:pointerover,Border#border2:pointerover">
			<Setter Property="RenderTransform">
				<Setter.Value>
					<ScaleTransform ScaleX="0.9" ScaleY="0.9" />
				</Setter.Value>
			</Setter>
		</Style>
		
		<!--错误校验提示-->
		<Style Selector="TextBox /template/ DataValidationErrors,CalendarDatePicker /template/ DataValidationErrors">
			<Setter Property="Theme" Value="{DynamicResource TooltipDataValidationErrors}" />
		</Style>

	</Application.Styles>
</Application>